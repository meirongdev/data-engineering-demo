#!/usr/bin/env bash
# Repo-tracked git pre-commit hook. Enable it once with:  make hooks
# (which sets core.hooksPath=.githooks). It runs the static checks and blocks
# the commit if any fail. Bypass a one-off with:  git commit --no-verify
set -euo pipefail
exec "$(git rev-parse --show-toplevel)/scripts/check.sh"
